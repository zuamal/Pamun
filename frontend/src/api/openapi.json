  "components": {
    "schemas": {
      "Body_upload_documents_api_documents_upload_post": {
        "properties": {
          "files": {
            "items": {
              "type": "string",
              "contentMediaType": "application/octet-stream"
            },
            "type": "array",
            "title": "Files"
          }
        },
        "type": "object",
        "required": [
          "files"
        ],
        "title": "Body_upload_documents_api_documents_upload_post"
      },
      "BundleInfo": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "files": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Files"
          }
        },
        "type": "object",
        "required": [
          "name",
          "files"
        ],
        "title": "BundleInfo"
      },
      "DemoBundleInfo": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "file_count": {
            "type": "integer",
            "title": "File Count"
          }
        },
        "type": "object",
        "required": [
          "name",
          "description",
          "file_count"
        ],
        "title": "DemoBundleInfo"
      },
      "DemoLoadResponse": {
        "properties": {
          "bundle": {
            "type": "string",
            "title": "Bundle"
          },
          "requirements": {
            "type": "integer",
            "title": "Requirements"
          },
          "edges": {
            "type": "integer",
            "title": "Edges"
          }
        },
        "type": "object",
        "required": [
          "bundle",
          "requirements",
          "edges"
        ],
        "title": "DemoLoadResponse"
      },
      "Document": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique document ID (auto-generated)"
          },
          "filename": {
            "type": "string",
            "title": "Filename",
            "description": "Original filename"
          },
          "format": {
            "$ref": "#/components/schemas/DocumentFormat"
          },
          "raw_text": {
            "type": "string",
            "title": "Raw Text",
            "description": "Plain text extracted from document"
          },
          "file_size": {
            "type": "integer",
            "title": "File Size",
            "description": "Original file size in bytes"
          },
          "uploaded_at": {
            "type": "string",
            "format": "date-time",
            "title": "Uploaded At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "filename",
          "format",
          "raw_text",
          "file_size"
        ],
        "title": "Document"
      },
      "DocumentFormat": {
        "type": "string",
        "enum": [
          "markdown",
          "docx",
          "pdf"
        ],
        "title": "DocumentFormat"
      },
      "DocumentListResponse": {
        "properties": {
          "documents": {
            "items": {
              "$ref": "#/components/schemas/Document"
            },
            "type": "array",
            "title": "Documents"
          }
        },
        "type": "object",
        "required": [
          "documents"
        ],
        "title": "DocumentListResponse"
      },
      "Edge": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique edge ID (auto-generated)"
          },
          "source_id": {
            "type": "string",
            "title": "Source Id",
            "description": "Source requirement ID"
          },
          "target_id": {
            "type": "string",
            "title": "Target Id",
            "description": "Target requirement ID"
          },
          "relation_type": {
            "$ref": "#/components/schemas/RelationType"
          },
          "evidence": {
            "type": "string",
            "title": "Evidence",
            "description": "Evidence sentence from source docs"
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence",
            "description": "LLM confidence score (for review prioritization)"
          },
          "status": {
            "$ref": "#/components/schemas/EdgeStatus",
            "default": "pending"
          }
        },
        "type": "object",
        "required": [
          "id",
          "source_id",
          "target_id",
          "relation_type",
          "evidence",
          "confidence"
        ],
        "title": "Edge"
      },
      "EdgeCreateRequest": {
        "properties": {
          "source_id": {
            "type": "string",
            "title": "Source Id"
          },
          "target_id": {
            "type": "string",
            "title": "Target Id"
          },
